<?xml version="1.0" encoding="utf-8"?>
<Feature SiLA2Version="1.1" FeatureVersion="1.0.0" MaturityLevel="Draft"
         Originator="it.bicoccalab" Category="automation"
         xmlns="http://www.sila-standard.org"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.sila-standard.org https://gitlab.com/SiLA2/sila_base/raw/master/schema/FeatureDefinition.xsd">
    
    <Identifier>TaskManagement</Identifier>
    <DisplayName>Task Management</DisplayName>
    <Description>
        High-level task management for the mobile robot system.
        
        This feature allows the orchestrator to:
        - Discover available tasks from the robot controller
        - Execute tasks with progress feedback
        - Monitor task execution status
        - Cancel running tasks
        
        The robot PC exposes predefined tasks via ROS action/service:
        - Action Server: /setup1/state_exec (executionCommand.action)
        - Service: /setup1/getSubtasksInfo (getSubtaskInfo.srv)
        
        Each task consists of a root task with multiple subtasks.
        Feedback is provided during execution showing current subtask.
    </Description>
    
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                        DEFINED TYPES                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <DefinedExecutionError Identifier="TaskNotFound">
        <DisplayName>Task Not Found</DisplayName>
        <Description>The specified task ID does not exist</Description>
    </DefinedExecutionError>
    
    <DefinedExecutionError Identifier="TaskExecutionFailed">
        <DisplayName>Task Execution Failed</DisplayName>
        <Description>The task failed during execution</Description>
    </DefinedExecutionError>
    
    <DefinedExecutionError Identifier="RobotNotConnected">
        <DisplayName>Robot Not Connected</DisplayName>
        <Description>Cannot communicate with the robot controller</Description>
    </DefinedExecutionError>
    
    <DataTypeDefinition Identifier="TaskInfo">
        <DisplayName>Task Information</DisplayName>
        <Description>Information about an available task</Description>
        <DataType>
            <Structure>
                <Element Identifier="TaskId">
                    <DisplayName>Task ID</DisplayName>
                    <Description>Unique identifier for the task</Description>
                    <DataType><Basic>String</Basic></DataType>
                </Element>
                <Element Identifier="TaskName">
                    <DisplayName>Task Name</DisplayName>
                    <Description>Human-readable name of the task</Description>
                    <DataType><Basic>String</Basic></DataType>
                </Element>
                <Element Identifier="SubtaskCount">
                    <DisplayName>Subtask Count</DisplayName>
                    <Description>Number of subtasks in this task</Description>
                    <DataType><Basic>Integer</Basic></DataType>
                </Element>
            </Structure>
        </DataType>
    </DataTypeDefinition>
    
    <DataTypeDefinition Identifier="TaskExecutionMode">
        <DisplayName>Task Execution Mode</DisplayName>
        <Description>Mode for task execution</Description>
        <DataType>
            <Constrained>
                <DataType><Basic>String</Basic></DataType>
                <Constraints>
                    <Set>
                        <Value>Normal</Value>
                        <Value>StepByStep</Value>
                        <Value>DryRun</Value>
                    </Set>
                </Constraints>
            </Constrained>
        </DataType>
    </DataTypeDefinition>
    
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                            PROPERTIES                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Property Identifier="AvailableTasks" Observable="No">
        <DisplayName>Available Tasks</DisplayName>
        <Description>
            List of tasks available for execution on the robot.
            This list is populated from the robot controller via ROS service.
        </Description>
        <DataType>
            <List>
                <DataType>
                    <DataTypeIdentifier>TaskInfo</DataTypeIdentifier>
                </DataType>
            </List>
        </DataType>
    </Property>
    
    <Property Identifier="CurrentTaskId" Observable="Yes">
        <DisplayName>Current Task ID</DisplayName>
        <Description>ID of the currently executing task, or empty if idle</Description>
        <DataType><Basic>String</Basic></DataType>
    </Property>
    
    <Property Identifier="CurrentSubtask" Observable="Yes">
        <DisplayName>Current Subtask</DisplayName>
        <Description>Name of the subtask currently being executed</Description>
        <DataType><Basic>String</Basic></DataType>
    </Property>
    
    <Property Identifier="TaskStatus" Observable="Yes">
        <DisplayName>Task Status</DisplayName>
        <Description>Current status of task execution</Description>
        <DataType>
            <Constrained>
                <DataType><Basic>String</Basic></DataType>
                <Constraints>
                    <Set>
                        <Value>Idle</Value>
                        <Value>Executing</Value>
                        <Value>Paused</Value>
                        <Value>Completed</Value>
                        <Value>Failed</Value>
                        <Value>Cancelled</Value>
                    </Set>
                </Constraints>
            </Constrained>
        </DataType>
    </Property>
    
    <Property Identifier="RobotConnectionStatus" Observable="Yes">
        <DisplayName>Robot Connection Status</DisplayName>
        <Description>Status of the connection to the robot controller (ROS)</Description>
        <DataType>
            <Constrained>
                <DataType><Basic>String</Basic></DataType>
                <Constraints>
                    <Set>
                        <Value>Connected</Value>
                        <Value>Disconnected</Value>
                        <Value>Connecting</Value>
                        <Value>Error</Value>
                    </Set>
                </Constraints>
            </Constrained>
        </DataType>
    </Property>
    
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--                            COMMANDS                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <Command Identifier="RefreshTasks" Observable="No">
        <DisplayName>Refresh Tasks</DisplayName>
        <Description>
            Query the robot controller for available tasks.
            Updates the AvailableTasks property.
        </Description>
        <Response>
            <Parameter Identifier="TaskCount">
                <DisplayName>Task Count</DisplayName>
                <Description>Number of tasks discovered</Description>
                <DataType><Basic>Integer</Basic></DataType>
            </Parameter>
        </Response>
        <DefinedExecutionErrors>
            <Identifier>RobotNotConnected</Identifier>
        </DefinedExecutionErrors>
    </Command>
    
    <Command Identifier="ExecuteTask" Observable="Yes">
        <DisplayName>Execute Task</DisplayName>
        <Description>
            Execute a task on the robot by sending a goal to the ROS action server.
            
            The task is identified by its ID (startTaskID in ROS).
            Progress feedback is provided via the IntermediateResponse.
        </Description>
        <Parameter Identifier="TaskId">
            <DisplayName>Task ID</DisplayName>
            <Description>ID of the task to execute (dropdown populated from AvailableTasks)</Description>
            <DataType><Basic>String</Basic></DataType>
        </Parameter>
        <Parameter Identifier="ExecutionMode">
            <DisplayName>Execution Mode</DisplayName>
            <Description>How to execute the task</Description>
            <DataType>
                <DataTypeIdentifier>TaskExecutionMode</DataTypeIdentifier>
            </DataType>
        </Parameter>
        <IntermediateResponse>
            <Parameter Identifier="CurrentSubtask">
                <DisplayName>Current Subtask</DisplayName>
                <Description>Name of the subtask being executed</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
            <Parameter Identifier="Progress">
                <DisplayName>Progress</DisplayName>
                <Description>Execution progress percentage (0-100)</Description>
                <DataType><Basic>Real</Basic></DataType>
            </Parameter>
            <Parameter Identifier="Status">
                <DisplayName>Status</DisplayName>
                <Description>Current execution status</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
        </IntermediateResponse>
        <Response>
            <Parameter Identifier="Success">
                <DisplayName>Success</DisplayName>
                <Description>Whether the task completed successfully</Description>
                <DataType><Basic>Boolean</Basic></DataType>
            </Parameter>
            <Parameter Identifier="Message">
                <DisplayName>Message</DisplayName>
                <Description>Result message from the robot controller</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
            <Parameter Identifier="ExecutionTime">
                <DisplayName>Execution Time</DisplayName>
                <Description>Total execution time in seconds</Description>
                <DataType><Basic>Real</Basic></DataType>
            </Parameter>
        </Response>
        <DefinedExecutionErrors>
            <Identifier>TaskNotFound</Identifier>
            <Identifier>TaskExecutionFailed</Identifier>
            <Identifier>RobotNotConnected</Identifier>
        </DefinedExecutionErrors>
    </Command>
    
    <Command Identifier="CancelTask" Observable="No">
        <DisplayName>Cancel Task</DisplayName>
        <Description>
            Cancel the currently executing task.
            Sends a cancel request to the ROS action server.
        </Description>
        <Response>
            <Parameter Identifier="Cancelled">
                <DisplayName>Cancelled</DisplayName>
                <Description>Whether the task was successfully cancelled</Description>
                <DataType><Basic>Boolean</Basic></DataType>
            </Parameter>
        </Response>
    </Command>
    
    <Command Identifier="GetTaskDetails" Observable="No">
        <DisplayName>Get Task Details</DisplayName>
        <Description>
            Get detailed information about a specific task, including all subtasks.
        </Description>
        <Parameter Identifier="TaskId">
            <DisplayName>Task ID</DisplayName>
            <Description>ID of the task to query</Description>
            <DataType><Basic>String</Basic></DataType>
        </Parameter>
        <Response>
            <Parameter Identifier="TaskId">
                <DisplayName>Task ID</DisplayName>
                <Description>ID of the task</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
            <Parameter Identifier="TaskName">
                <DisplayName>Task Name</DisplayName>
                <Description>Human-readable name of the task</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
            <Parameter Identifier="Subtasks">
                <DisplayName>Subtasks</DisplayName>
                <Description>JSON array of subtask information</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
        </Response>
        <DefinedExecutionErrors>
            <Identifier>TaskNotFound</Identifier>
        </DefinedExecutionErrors>
    </Command>
    
    <Command Identifier="ConnectToRobot" Observable="No">
        <DisplayName>Connect to Robot</DisplayName>
        <Description>
            Establish connection to the robot controller via ROS.
            This initializes the ROS node and connects to the action server.
        </Description>
        <Parameter Identifier="RosMasterUri">
            <DisplayName>ROS Master URI</DisplayName>
            <Description>URI of the ROS master (e.g., http://192.168.1.100:11311). Leave empty to use config default.</Description>
            <DataType><Basic>String</Basic></DataType>
        </Parameter>
        <Response>
            <Parameter Identifier="Connected">
                <DisplayName>Connected</DisplayName>
                <Description>Whether connection was successful</Description>
                <DataType><Basic>Boolean</Basic></DataType>
            </Parameter>
            <Parameter Identifier="Message">
                <DisplayName>Message</DisplayName>
                <Description>Connection status message</Description>
                <DataType><Basic>String</Basic></DataType>
            </Parameter>
        </Response>
    </Command>

</Feature>
