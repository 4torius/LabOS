<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  SiLA2 Feature Definition per Tecan M200 Pro Plate Reader
  Conforme a SiLA 2.1 Standard
  
  Questa Feature espone le funzionalità del lettore di piastre Tecan:
  - Controllo connessione
  - Movimento piastra (In/Out)
  - Controllo temperatura
  - Esecuzione misurazioni (Absorbance, Fluorescence, Luminescence)
  - Recupero risultati in formato AnIML
-->
<Feature xmlns="http://www.sila-standard.org"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.sila-standard.org https://gitlab.com/SiLA2/sila_base/-/raw/master/schema/FeatureDefinition.xsd"
         SiLA2Version="1.1"
         FeatureVersion="1.0.0"
         MaturityLevel="Draft"
         Originator="it.chemlab"
         Category="instruments.platereader">
  
  <Identifier>PlateReaderService</Identifier>
  <DisplayName>Plate Reader Service</DisplayName>
  <Description>
    SiLA2 Feature per il controllo del lettore di piastre Tecan M200 Pro.
    Supporta misurazioni di Assorbanza, Fluorescenza e Luminescenza.
    I risultati vengono restituiti in formato AnIML per la compatibilità con i sistemi LIMS.
  </Description>

  <!-- ======================= METADATA ======================= -->
  <Metadata>
    <Parameter Identifier="VendorName">
      <DisplayName>Vendor Name</DisplayName>
      <Description>Nome del produttore dello strumento</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
      <Value>Tecan</Value>
    </Parameter>
    <Parameter Identifier="InstrumentModel">
      <DisplayName>Instrument Model</DisplayName>
      <Description>Modello dello strumento</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
      <Value>Infinite M200 Pro</Value>
    </Parameter>
  </Metadata>

  <!-- ======================= PROPERTIES ======================= -->
  
  <!-- Property: Stato Connessione -->
  <Property Identifier="IsConnected" Observable="Yes">
    <DisplayName>Is Connected</DisplayName>
    <Description>Indica se lo strumento è attualmente connesso</Description>
    <DataType>
      <Basic>Boolean</Basic>
    </DataType>
  </Property>

  <!-- Property: Stato Operativo -->
  <Property Identifier="OperationalStatus" Observable="Yes">
    <DisplayName>Operational Status</DisplayName>
    <Description>Stato operativo corrente dello strumento</Description>
    <DataType>
      <Constrained>
        <DataType>
          <Basic>String</Basic>
        </DataType>
        <Constraints>
          <Set>
            <Value>Idle</Value>
            <Value>Busy</Value>
            <Value>Error</Value>
            <Value>Disconnected</Value>
          </Set>
        </Constraints>
      </Constrained>
    </DataType>
  </Property>

  <!-- Property: Temperatura Corrente -->
  <Property Identifier="CurrentTemperature" Observable="Yes">
    <DisplayName>Current Temperature</DisplayName>
    <Description>Temperatura corrente della piastra in gradi Celsius</Description>
    <DataType>
      <Basic>Real</Basic>
    </DataType>
  </Property>

  <!-- Property: Info Strumento -->
  <Property Identifier="InstrumentInfo" Observable="No">
    <DisplayName>Instrument Information</DisplayName>
    <Description>Informazioni sullo strumento connesso</Description>
    <DataType>
      <Structure>
        <Element Identifier="SerialNumber">
          <DisplayName>Serial Number</DisplayName>
          <Description>Numero di serie</Description>
          <DataType>
            <Basic>String</Basic>
          </DataType>
        </Element>
        <Element Identifier="FirmwareVersion">
          <DisplayName>Firmware Version</DisplayName>
          <Description>Versione del firmware</Description>
          <DataType>
            <Basic>String</Basic>
          </DataType>
        </Element>
        <Element Identifier="ProductName">
          <DisplayName>Product Name</DisplayName>
          <Description>Nome del prodotto</Description>
          <DataType>
            <Basic>String</Basic>
          </DataType>
        </Element>
        <Element Identifier="IsSimulated">
          <DisplayName>Is Simulated</DisplayName>
          <Description>Se true, è in modalità simulazione</Description>
          <DataType>
            <Basic>Boolean</Basic>
          </DataType>
        </Element>
      </Structure>
    </DataType>
  </Property>

  <!-- ======================= COMMANDS ======================= -->

  <!-- Command: Connect -->
  <Command Identifier="Connect" Observable="No">
    <DisplayName>Connect</DisplayName>
    <Description>Connette al lettore di piastre Tecan</Description>
    <Parameter Identifier="ConnectionString">
      <DisplayName>Connection String</DisplayName>
      <Description>Stringa di connessione (es. "porttype=USB|SIM, type=READER")</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se la connessione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>ConnectionFailed</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: Disconnect -->
  <Command Identifier="Disconnect" Observable="No">
    <DisplayName>Disconnect</DisplayName>
    <Description>Disconnette dal lettore di piastre</Description>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se la disconnessione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
  </Command>

  <!-- Command: Plate In -->
  <Command Identifier="PlateIn" Observable="No">
    <DisplayName>Plate In</DisplayName>
    <Description>Porta la piastra all'interno dello strumento</Description>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se l'operazione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>NotConnected</Identifier>
      <Identifier>MovementFailed</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: Plate Out -->
  <Command Identifier="PlateOut" Observable="No">
    <DisplayName>Plate Out</DisplayName>
    <Description>Espelle la piastra dallo strumento</Description>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se l'operazione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>NotConnected</Identifier>
      <Identifier>MovementFailed</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: Set Temperature -->
  <Command Identifier="SetTemperature" Observable="No">
    <DisplayName>Set Temperature</DisplayName>
    <Description>Imposta la temperatura target della piastra</Description>
    <Parameter Identifier="TargetTemperature">
      <DisplayName>Target Temperature</DisplayName>
      <Description>Temperatura desiderata in gradi Celsius (es. 37.0)</Description>
      <DataType>
        <Constrained>
          <DataType>
            <Basic>Real</Basic>
          </DataType>
          <Constraints>
            <MinimalInclusive>4.0</MinimalInclusive>
            <MaximalInclusive>45.0</MaximalInclusive>
          </Constraints>
        </Constrained>
      </DataType>
    </Parameter>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se l'impostazione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>NotConnected</Identifier>
      <Identifier>TemperatureOutOfRange</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: Turn Off Temperature Control -->
  <Command Identifier="TurnOffTemperature" Observable="No">
    <DisplayName>Turn Off Temperature</DisplayName>
    <Description>Disattiva il controllo della temperatura</Description>
    <Response Identifier="Success">
      <DisplayName>Success</DisplayName>
      <Description>True se l'operazione è riuscita</Description>
      <DataType>
        <Basic>Boolean</Basic>
      </DataType>
    </Response>
  </Command>

  <!-- Command: Run Measurement (Observable - Long Running) -->
  <Command Identifier="RunMeasurement" Observable="Yes">
    <DisplayName>Run Measurement</DisplayName>
    <Description>
      Esegue una misurazione utilizzando un protocollo .mdfx.
      Questo è un comando Observable (asincrono) perché le misurazioni 
      possono richiedere tempo.
    </Description>
    <Parameter Identifier="ProtocolFile">
      <DisplayName>Protocol File</DisplayName>
      <Description>Nome del file di protocollo .mdfx (deve esistere nella cartella Protocols)</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Parameter Identifier="PlateID">
      <DisplayName>Plate ID</DisplayName>
      <Description>Identificativo univoco della piastra per la tracciabilità</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Parameter Identifier="SampleSetID">
      <DisplayName>Sample Set ID</DisplayName>
      <Description>Identificativo del set di campioni (per AnIML)</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Parameter Identifier="PlateType">
      <DisplayName>Plate Type</DisplayName>
      <Description>Nome iControl della piastra (es. GRE96ft_Corning360). Se vuoto, usa il default da appsettings.json.</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <IntermediateResponse Identifier="Progress">
      <DisplayName>Progress</DisplayName>
      <Description>Percentuale di completamento della misurazione</Description>
      <DataType>
        <Basic>Integer</Basic>
      </DataType>
    </IntermediateResponse>
    <IntermediateResponse Identifier="StatusMessage">
      <DisplayName>Status Message</DisplayName>
      <Description>Messaggio di stato corrente</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </IntermediateResponse>
    <Response Identifier="MeasurementResult">
      <DisplayName>Measurement Result</DisplayName>
      <Description>Risultato della misurazione</Description>
      <DataType>
        <Structure>
          <Element Identifier="AnIMLDocument">
            <DisplayName>AnIML Document</DisplayName>
            <Description>Risultati in formato AnIML XML (base64 encoded)</Description>
            <DataType>
              <Basic>Binary</Basic>
            </DataType>
          </Element>
          <Element Identifier="AnIMLFilePath">
            <DisplayName>AnIML File Path</DisplayName>
            <Description>Percorso del file AnIML salvato localmente</Description>
            <DataType>
              <Basic>String</Basic>
            </DataType>
          </Element>
          <Element Identifier="ExcelFilePath">
            <DisplayName>Excel File Path</DisplayName>
            <Description>Percorso del file Excel generato</Description>
            <DataType>
              <Basic>String</Basic>
            </DataType>
          </Element>
          <Element Identifier="MeasurementType">
            <DisplayName>Measurement Type</DisplayName>
            <Description>Tipo di misurazione eseguita</Description>
            <DataType>
              <Constrained>
                <DataType>
                  <Basic>String</Basic>
                </DataType>
                <Constraints>
                  <Set>
                    <Value>Absorbance</Value>
                    <Value>Fluorescence</Value>
                    <Value>Luminescence</Value>
                    <Value>Mixed</Value>
                  </Set>
                </Constraints>
              </Constrained>
            </DataType>
          </Element>
        </Structure>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>NotConnected</Identifier>
      <Identifier>ProtocolNotFound</Identifier>
      <Identifier>MeasurementFailed</Identifier>
      <Identifier>InstrumentBusy</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: Get AnIML Result -->
  <Command Identifier="GetAnIMLResult" Observable="No">
    <DisplayName>Get AnIML Result</DisplayName>
    <Description>Recupera un risultato AnIML precedente dato l'ID della piastra</Description>
    <Parameter Identifier="PlateID">
      <DisplayName>Plate ID</DisplayName>
      <Description>Identificativo della piastra</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Response Identifier="AnIMLDocument">
      <DisplayName>AnIML Document</DisplayName>
      <Description>Documento AnIML in formato binario (XML encoded in base64)</Description>
      <DataType>
        <Basic>Binary</Basic>
      </DataType>
    </Response>
    <DefinedExecutionErrors>
      <Identifier>ResultNotFound</Identifier>
    </DefinedExecutionErrors>
  </Command>

  <!-- Command: List Available Protocols -->
  <Command Identifier="ListProtocols" Observable="No">
    <DisplayName>List Protocols</DisplayName>
    <Description>Elenca tutti i protocolli .mdfx disponibili</Description>
    <Response Identifier="Protocols">
      <DisplayName>Protocols</DisplayName>
      <Description>Lista dei nomi dei protocolli disponibili</Description>
      <DataType>
        <List>
          <DataType>
            <Basic>String</Basic>
          </DataType>
        </List>
      </DataType>
    </Response>
  </Command>

  <!-- ======================= DEFINED EXECUTION ERRORS ======================= -->
  
  <DefinedExecutionError Identifier="ConnectionFailed">
    <DisplayName>Connection Failed</DisplayName>
    <Description>Impossibile connettersi allo strumento</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="NotConnected">
    <DisplayName>Not Connected</DisplayName>
    <Description>Lo strumento non è connesso. Chiamare Connect() prima.</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="MovementFailed">
    <DisplayName>Movement Failed</DisplayName>
    <Description>Il movimento della piastra è fallito</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="TemperatureOutOfRange">
    <DisplayName>Temperature Out Of Range</DisplayName>
    <Description>La temperatura richiesta è fuori dal range supportato</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="ProtocolNotFound">
    <DisplayName>Protocol Not Found</DisplayName>
    <Description>Il file di protocollo specificato non è stato trovato</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="MeasurementFailed">
    <DisplayName>Measurement Failed</DisplayName>
    <Description>La misurazione è fallita</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="InstrumentBusy">
    <DisplayName>Instrument Busy</DisplayName>
    <Description>Lo strumento è occupato con un'altra misurazione</Description>
  </DefinedExecutionError>

  <DefinedExecutionError Identifier="ResultNotFound">
    <DisplayName>Result Not Found</DisplayName>
    <Description>Il risultato richiesto non è stato trovato</Description>
  </DefinedExecutionError>

</Feature>
