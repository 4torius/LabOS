{
  "TecanSiLA2Server": {
    // ═══════════════════════════════════════════════════════════════════════════
    // CONFIGURAZIONE SERVER SILA2
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Nome del server per discovery
    "ServerName": "Tecan M200 Pro",
    
    // Porta gRPC su cui il server è in ascolto
    "GrpcPort": 50051,
    
    // Indirizzo di bind (0.0.0.0 per tutte le interfacce, localhost per solo locale)
    "BindAddress": "0.0.0.0",
    
    // ═══════════════════════════════════════════════════════════════════════════
    // PERCORSI FILE SYSTEM
    // Usare percorsi ASSOLUTI per evitare problemi con la directory di lavoro
    // Oppure percorsi relativi dalla cartella dell'eseguibile (bin/Debug/net48)
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Percorso per i protocolli .mdfx
    // Esempi:
    //   - Assoluto: "C:/Users/inspection/Desktop/TecanSiLAServer/Protocols"
    //   - Relativo: "../../Library/Analysis" (dalla cartella di appsettings.json)
    //   - Vuoto: usa default "Protocols" nella cartella exe
    "ProtocolsPath": "../../Library/Analysis",
    
    // Percorso per i risultati (XML, Excel, AnIML)
    // Esempi:
    //   - Assoluto: "C:/Users/inspection/Desktop/TecanSiLAServer/Results"
    //   - Relativo: "../../Results" (dalla cartella di appsettings.json)
    "ResultsPath": "../../Results",
    
    // ═══════════════════════════════════════════════════════════════════════════
    // CONNESSIONE STRUMENTO
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Stringa di connessione Tecan
    // Valori speciali:
    //   - "" o "default" o "usb" : Solo strumenti USB reali (CONSIGLIATO)
    //   - "sim"                  : Solo simulatori (per test)
    //   - "usb_auto" o "last"    : Auto-connetti all'ultimo strumento USB
    //   - "any"                  : USB + Simulatori (può connettersi a simulatore!)
    //   - stringa custom         : es. "porttype=USB, type=READER, option=Infinite"
    // 
    // NOTA: Se la finestra di selezione strumento è vuota, significa che:
    //   1. Il Tecan M200 non è acceso
    //   2. Il cavo USB non è collegato
    //   3. I driver USB Tecan non sono installati
    "DefaultConnectionString": "sim",
    
    // Auto-connessione all'avvio del server
    "AutoConnectOnStartup": false,
    
    // ═══════════════════════════════════════════════════════════════════════════
    // OUTPUT RISULTATI
    // ═══════════════════════════════════════════════════════════════════════════
    
    // XML: Sempre generato (formato nativo Tecan)
    
    // Genera file Excel (.xls) - DISABILITATO perché causa hang su GC.WaitForPendingFinalizers
    // Il COM ExcelOutput della libreria Tecan non finalizza correttamente
    "GenerateExcel": true,
    
    // Genera file AnIML (standard ASTM E1947)
    "GenerateAnIML": true,
    
    // Genera file CSV (formato i-control) - disabilitato di default
    "GenerateCsv": false,
    
    // ═══════════════════════════════════════════════════════════════════════════
    // IMPOSTAZIONI AVANZATE
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Timeout connessione in secondi (60 sec per USB che può richiedere più tempo)
    "ConnectionTimeoutSeconds": 60,
    
    // Timeout misurazione in secondi (0 = illimitato)
    "MeasurementTimeoutSeconds": 0,
    
    // Mostra risultati polarizzazione
    "ShowPolarization": true,
    
    // Mostra risultati anisotropia
    "ShowAnisotropy": true
  },
  
  // ═══════════════════════════════════════════════════════════════════════════
  // LOGGING
  // ═══════════════════════════════════════════════════════════════════════════
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Grpc": "Warning",
      "TecanSiLA2Server": "Debug"
    }
  }
}
